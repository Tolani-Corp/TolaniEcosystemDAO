{
  "name": "tolani-ecosystem-dao",
  "version": "1.0.0",
  "description": "Tolani Ecosystem DAO - Decentralized Governance for TUT Token",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:tut:local": "hardhat run scripts/deploy-tut-token.js --network localhost",
    "deploy:tut:sepolia": "hardhat run scripts/deploy-tut-token.js --network sepolia",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "node": "hardhat node",
    "setup-roles": "hardhat run scripts/setup-roles.js",
    "delegate": "hardhat run scripts/delegate.js",
    "propose": "hardhat run scripts/propose.js",
    "vote": "hardhat run scripts/vote.js",
    "execute": "hardhat run scripts/execute.js",
    "status": "hardhat run scripts/proposal-status.js",
    "reconcile:base": "hardhat run --no-compile scripts/deployments/reconcile-mainnet-status.js --network base",
    "roles:base": "hardhat run --no-compile scripts/deployments/transfer-to-multisig.js --network base",
    "fund:base": "hardhat run --no-compile scripts/deployments/fund-base-tut.js --network base",
    "staking:deploy:base": "hardhat run --no-compile scripts/deployments/deploy-clean-staking.js --network base",
    "verify": "hardhat verify"
  },
  "keywords": [
    "dao",
    "governance",
    "ethereum",
    "hardhat",
    "tut",
    "tolani"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "dotenv": "^17.2.3",
    "hardhat": "^2.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tolani-Corp/TolaniToken"
  },
  "dependencies": {
    "@eth-optimism/viem": "^0.4.14",
    "cors": "^2.8.6",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "viem": "^2.43.4"
  }
}
